# 阿里云百炼 API Key（运行时必填，也可交互式输入）
LLM_API_KEY=

# 阿里云百炼应用 AppId（运行时必填，也可交互式输入）
LLM_APP_ID=

# 百炼子业务空间 ID（默认 llm-shwq55idtv5plnag）
WORKSPACE_ID=llm-shwq55idtv5plnag

# 批量处理并发数（默认 10，最大 200）
POOL_SIZE=4

# 阿里云 AccessKey（用于文件上传功能）
# 本地开发：留空则从环境变量读取
# 分发打包：build.sh 编译时通过 -ldflags 注入到二进制中
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
