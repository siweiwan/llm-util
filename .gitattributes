# 自动检测文本文件并规范化行尾
* text=auto

# Go 源码文件使用 LF
*.go text eol=lf
*.mod text eol=lf
*.sum text eol=lf

# 配置文件使用 LF
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.env text eol=lf
*.example text eol=lf

# Shell 脚本使用 LF
*.sh text eol=lf
*.bat text eol=crlf

# 二进制文件不处理
*.exe binary
*.pdf binary
*.xlsx binary
*.png binary
*.jpg binary
*.jpeg binary
